# Postgres
DB_USER=user
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432
DB_DATABASE=kepas_design

# Express
PORT=4200

# When mounted behind a reverse proxy at a sub-path (e.g. /tools/design-editor),
# set BASE_PATH, API_PATH, and TEMPLATES_PATH so the rendered HTML emits
# the right URLs. Defaults work for standalone localhost runs.
BASE_PATH=
API_PATH=/api/designs
TEMPLATES_PATH=/templates/design-editor
